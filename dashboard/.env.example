# ── Dashboard Environment Variables ─────────────────────────
# Copy this file to .env for local dev
# In Vercel: set these in Project Settings → Environment Variables

# Backend URL (no trailing slash)
# Local dev:   http://localhost:8000
# Production:  https://agromindai-q5m4.onrender.com  (or your Render URL)
VITE_API_BASE=http://localhost:8000

# WebSocket URL (no trailing slash)
# Local dev:   ws://localhost:8000
# Production:  wss://agromindai-q5m4.onrender.com
VITE_WS_BASE=ws://localhost:8000
